          "id": "step_review",
          "name": "Review",
          "position": 3,
          "kind": "manual",
          "gates": [
            {
              "id": "gate_review_clear",
              "kind": "review_clear",
              "prompt": "Review has no blocking findings."
            }
          ]
        }
      ]
