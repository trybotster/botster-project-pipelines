python3 - <<'PY'
import json
from pathlib import Path

manifest_path = Path("botster-package.json")
manifest = json.loads(manifest_path.read_text())

assert manifest["name"] == "project-pipelines"
assert manifest["kind"] == "plugin"
assert manifest["botster"].startswith(">=")
assert manifest["source"] == {"type": "path", "path": "."}
assert manifest["entrypoints"] == [
    {"runtime": "lua", "path": "plugin.lua", "bootstrap": False}
]
plugin_source = Path("plugin.lua").read_text()
assert "require(" not in plugin_source
assert "botster.register" in plugin_source
assert [group["id"] for group in manifest["configuration"]["groups"]] == ["defaults", "integrations"]
assert [field["key"] for field in manifest["configuration"]["fields"]] == [
    "default_spawn_target_id",
    "default_session_template_selector",
    "default_pipeline_mode",
    "workspace_id",
]
assert manifest["navigation"] == [
    {
        "id": "pipelines",
        "label": "Pipelines",
        "icon": "queue-list",
        "description": "Open the Project Pipelines operator workbench.",
        "target": {"kind": "surface", "surface_id": "project-pipelines.home"},
    }
]

surfaces = {surface["id"]: surface for surface in manifest["surfaces"]}
assert surfaces["project-pipelines.home"]["kind"] == "app"
assert surfaces["project-pipelines.settings"]["kind"] == "settings"
assert surfaces["project-pipelines.home"]["supports"] == ["render", "action"]
assert surfaces["project-pipelines.settings"]["supports"] == ["render"]
for surface in surfaces.values():
    assert "path" not in surface
    assert "route" not in surface
    assert "route_path" not in surface
assert {capability["surface"] for capability in manifest["capabilities"]} == {
    "surfaces",
    "mcp",
    "plugin_db",
}
PY

