python3 - <<'PY'
import json
from pathlib import Path

manifest = json.loads(Path("botster-package.json").read_text())
contract = json.loads(Path("fixtures/project_pipelines/domain_contract.json").read_text())
docs = Path("docs/domain-contract.md").read_text()

anchors = contract["manifest_anchors"]
assert anchors["package_name"] == manifest["name"]
assert anchors["capabilities"] == [capability["surface"] for capability in manifest["capabilities"]]
assert anchors["entrypoint"] == manifest["entrypoints"][0]["path"]
assert anchors["configuration"] == {
    "groups": [group["id"] for group in manifest["configuration"]["groups"]],
    "fields": [field["key"] for field in manifest["configuration"]["fields"]],
}
assert anchors["navigation"] == {
    "pipelines": {
        "label": "Pipelines",
        "target_surface": "project-pipelines.home",
    }
}

surfaces = {surface["id"]: surface for surface in manifest["surfaces"]}
assert anchors["surfaces"] == {
    "home": "project-pipelines.home",
    "settings": "project-pipelines.settings",
}
assert anchors["route_contract"] == {
    "manifest": "surface_ids_and_navigation_intent",
    "home": "project-pipelines.home",
    "settings": "project-pipelines.settings",
    "path_support": "hub_admitted_route_descriptors",
}
assert anchors["surfaces"]["home"] in surfaces
assert anchors["surfaces"]["settings"] in surfaces
for surface in surfaces.values():
    assert "path" not in surface
    assert "route" not in surface
    assert "route_path" not in surface
assert anchors["runtime"] == "session_template_lua_plugin"

required_domain_objects = {
    "project",
    "ticket",
    "pipeline_definition",
    "step",
    "gate",
    "artifact",
    "finding",
    "question",
    "answer",
    "run",
    "session_request",
    "pr_link",
    "provider_lifecycle_boundary",
    "event",
}
assert required_domain_objects <= set(contract["domain_objects"])

projects = {project["id"]: project for project in contract["projects"]}
tickets = {ticket["id"]: ticket for ticket in contract["tickets"]}
pipelines = {pipeline["id"]: pipeline for pipeline in contract["pipeline_definitions"]}
runs = {run["id"]: run for run in contract["runs"]}
session_requests = {request["id"]: request for request in contract["session_requests"]}
artifacts = {artifact["id"]: artifact for artifact in contract["artifacts"]}
questions = {question["id"]: question for question in contract["questions"]}
gate_ids = {
    gate["id"]
    for pipeline in pipelines.values()
    for step in pipeline["steps"]
    for gate in step["gates"]
}
step_ids = {
    step["id"]
    for pipeline in pipelines.values()
    for step in pipeline["steps"]
}

assert any(project["mode"] == "standalone" and project["workspace_id"] is None for project in projects.values())
assert any(project["mode"] == "workspace_linked" and project["workspace_id"] for project in projects.values())

for project in projects.values():
    assert project["repository"]["id"]
    assert project["repository"]["name"]
    assert project["repository"]["remote"].startswith("https://example.invalid/")
    assert project["spawn_target_id"]

for ticket in tickets.values():
    assert ticket["project_id"] in projects
    if ticket["workspace_id"] is not None:
        assert projects[ticket["project_id"]]["workspace_id"] == ticket["workspace_id"]
    for dependency_id in ticket["dependency_ticket_ids"]:
        assert dependency_id in tickets

for pipeline in pipelines.values():
    assert pipeline["project_id"] in projects
    positions = [step["position"] for step in pipeline["steps"]]
    assert positions == sorted(positions)
    assert positions[0] == 1

for run in runs.values():
    assert run["ticket_id"] in tickets
    assert run["pipeline_definition_id"] in pipelines
    assert run["current_step_id"] in step_ids
    assert run["worktree"]["kind"] == "provider_owned_reference"
    ticket = tickets[run["ticket_id"]]
    if ticket["workspace_id"] is None:
        assert run["workspace_session_group_id"] is None
    else:
        assert run["workspace_session_group_id"]
        assert run["workspace_id"]

for request in session_requests.values():
    assert request["run_id"] in runs
    assert request["step_id"] in step_ids
    assert request["ticket_id"] in tickets
    assert request["status"] in {"spawn_requested", "blocked"}
    assert request["template_selector"]
    if request["status"] == "spawn_requested":
        assert request["template_id"]
        assert request["session_id"]
        assert request["result"]["session_id"] == request["session_id"]
        assert request["result"]["template_id"] == request["template_id"]
        assert request["result"]["context_id"]
    else:
        assert request["diagnostic"]["status"] == "blocked"
        assert request["diagnostic"]["code"]
        assert request["result"]["ok"] is False
        assert request["result"]["error"]["status"] == "blocked"
    daemon_request = request["request"]
    if request["status"] == "spawn_requested":
        assert set(daemon_request) == {"template_id", "session_id", "target_id", "cwd", "environment", "context"}
        assert daemon_request["template_id"] == request["template_id"]
        assert daemon_request["session_id"] == request["session_id"]
    else:
        assert set(daemon_request) == {"target_id", "cwd", "environment", "context"}
    assert daemon_request["target_id"]
    context = daemon_request["context"]
    for field in ["worktree_path", "repo_path", "branch_name", "prompt", "ticket_id", "workspace_id", "metadata"]:
        assert field in context
    assert context["ticket_id"] == request["ticket_id"]
    assert context["metadata"]["owner_plugin"] == "project-pipelines"

for result in contract["gate_results"]:
    assert result["run_id"] in runs
    assert result["step_id"] in step_ids
    assert result["gate_id"] in gate_ids
    assert result["evidence_artifact_id"] in artifacts

for artifact in artifacts.values():
    assert artifact["run_id"] in runs
    assert artifact["step_id"] in step_ids

for finding in contract["findings"]:
    assert finding["run_id"] in runs
    assert finding["step_id"] in step_ids

for question in questions.values():
    assert question["run_id"] in runs
    assert question["ticket_id"] in tickets

for answer in contract["answers"]:
    assert answer["question_id"] in questions

for pr_link in contract["pr_links"]:
    assert pr_link["run_id"] in runs
    assert pr_link["ticket_id"] in tickets
    assert pr_link["provider"] == "generic_pr_provider"

for event in contract["events"]:
    assert event["run_id"] in runs
    assert event["kind"] in {
        "ticket_created",
        "run_started",
        "step_started",
        "step_activation_preserved",
        "session_template_spawn_requested",
        "session_template_spawn_failed",
        "session_template_spawn_blocked",
        "gate_submitted",
        "artifact_added",
        "finding_opened",
        "question_asked",
        "answer_recorded",
        "provider_pr_linked",
        "provider_pr_ready_for_review",
        "provider_pr_merged",
        "run_completed",
    }

assert contract["persistence_boundaries"]["runtime_storage_namespace"] == "plugin-data/project-pipelines"
assert "botster-workspaces" in contract["provider_capabilities"][0]["forbidden_runtime_imports"]
assert "botster-agents" in contract["provider_capabilities"][0]["forbidden_runtime_imports"]
assert "github" in contract["provider_capabilities"][0]["forbidden_runtime_imports"]
assert "codex" in contract["provider_capabilities"][0]["forbidden_runtime_imports"]

required_doc_phrases = [
    "standalone",
    "workspace-linked mode is additive",
    "Provider Capability Contract",
    "plugin-data/project-pipelines",
    "project-pipelines.home",
    "project-pipelines.settings",
    "navigation",
    "surface ids",
    "hub-admitted route descriptors",
    "route path fields",
    "project-pipelines-provider-dependency-status",
    "session_templates.spawn",
    "session_templates.resolve",
    "session_templates.list",
    "session_template_spawn_blocked",
    "status: \"blocked\"",
    "github_auth",
    "DaemonSessionTemplateRequest",
    "plugin database capability",
]
for phrase in required_doc_phrases:
    assert phrase in docs
PY

python3 - <<'PY'
import re
from pathlib import Path

patterns = [
    re.compile("/" + "Users" + "/"),
    re.compile("jason" + "conigliari", re.IGNORECASE),
    re.compile(r"[A-Za-z0-9._%+-]+" + "@" + r"[A-Za-z0-9.-]+\.[A-Za-z]{2,}"),
]
paths = [
    Path(".gitignore"),
    Path("README.md"),
    Path("botster-package.json"),
    Path("plugin.lua"),
    Path("script/test"),
    Path("docs/domain-contract.md"),
    Path("fixtures/project_pipelines/domain_contract.json"),
]

for path in paths:
    text = path.read_text()
    for pattern in patterns:
        if pattern.search(text):
            raise SystemExit(f"PII-like content found in {path}")
PY

python3 - <<'PY'
from pathlib import Path

runtime_files = [
    path
    for path in Path(".").rglob("*")
    if path.is_file()
    and ".git" not in path.parts
    and path.parts[:2] != ("fixtures", "project_pipelines")
]

for path in runtime_files:
    text = path.read_text(errors="ignore")
    if path == Path("script/test") or path.suffix == ".md":
        continue
    forbidden_markers = [
        "require('github",
        'require("github',
        "require('codex",
        'require("codex',
        "require('botster-workspaces",
        'require("botster-workspaces',
        "require('botster-agents",
        'require("botster-agents',
        "github.com/",
        "api.github.com",
    ]
    for marker in forbidden_markers:
        if marker in text:
            raise SystemExit(f"Provider/workspace implementation marker found in {path}: {marker}")
PY

lua <<'LUA'
package.path = "./?.lua;./?/init.lua;" .. package.path

local durable_store = {}

local function deep_copy(value)
  if type(value) ~= "table" then return value end
  local result = {}
  for key, nested in pairs(value) do
    result[key] = deep_copy(nested)
  end
  return result
end

local spawned_session_templates = {}
local fail_next_spawn_error = nil
local session_template_registry = {
  { id = "template_codex_runtime", name = "Codex Runtime", capabilities = { "codex", "implementation" } },
  { id = "template_workspace_runtime", name = "Workspace Runtime", capabilities = { "workspace" } },
  { id = "template_named_runtime", name = "Named Runtime", capabilities = { "named" } },
  { id = "template_capability_runtime", name = "Capability Runtime", capabilities = { "specialized.review" } },
}

botster = {
  capabilities = {
    plugin_db = {
      get = function(args)
        local record = durable_store[args.key]
        if record == nil then
          return {}
        end
        return { record = deep_copy(record) }
      end,
      set = function(args)
        durable_store[args.key] = {
          schema_version = args.schema_version,
          payload = deep_copy(args.payload),
        }
        return { ok = true }
      end,
    },
    session_templates = {
      resolve = function(selector)
        assert(type(selector) == "table", "session_templates.resolve must receive one selector table")
        if selector.kind == "name" then
          for _, template in ipairs(session_template_registry) do
            if template.name == selector.template_name then
              return deep_copy(template)
            end
          end
        elseif selector.kind == "capability" then
          for _, template in ipairs(session_template_registry) do
            for _, capability in ipairs(template.capabilities or {}) do
              if capability == selector.capability then
                return deep_copy(template)
              end
            end
          end
        end
        return { ok = false, error = { code = "session_template_unavailable", message = "no matching test template" } }
      end,
      list = function()
        return { templates = deep_copy(session_template_registry) }
      end,
      spawn = function(args)
        assert(type(args) == "table", "session_templates.spawn must receive one request table")
        assert(
          args.template_id == "template_codex_runtime"
            or args.template_id == "template_workspace_runtime"
            or args.template_id == "template_named_runtime"
            or args.template_id == "template_capability_runtime",
          "spawn request must carry template_id"
        )
        assert(args.session_id == nil or type(args.session_id) == "string", "spawn request session_id must be optional string")
        assert(type(args.target_id) == "string" and args.target_id ~= "", "spawn request must carry target_id")
        assert(type(args.context) == "table", "spawn request must carry context")
        assert(
          args.context.ticket_id == "ticket_runtime_one"
            or args.context.ticket_id == "ticket_runtime_workspace",
          "spawn context must carry ticket_id"
        )
        assert(type(args.context.metadata) == "table", "spawn context must carry metadata")
        for key, value in pairs(args.environment or {}) do
          assert(type(key) == "string" and type(value) == "string", "spawn environment must be string keyed string values")
        end
        for key, value in pairs(args.context.metadata) do
          assert(type(key) == "string" and type(value) == "string", "spawn metadata must be string keyed string values")
        end
        if fail_next_spawn_error then
          local message = fail_next_spawn_error
          fail_next_spawn_error = nil
          error(message)
        end
        table.insert(spawned_session_templates, deep_copy(args))
        return {
          session_id = args.session_id or "session_from_hub_" .. tostring(#spawned_session_templates),
          lifecycle = "spawned",
          template_id = args.template_id,
          context_id = "context_from_hub_" .. tostring(#spawned_session_templates),
          context_keys = { "ticket_id", "metadata" },
        }
      end,
    },
  },
  register = function(spec)
    return spec
  end,
}

local plugin = dofile("plugin.lua")
assert(type(plugin) == "table", "plugin.lua must return a registration table")
assert(type(plugin.tools) == "table" and #plugin.tools >= 14, "plugin must register CRUD/context/entity/activation tools")
assert(type(plugin.handlers) == "table" and #plugin.handlers == 7, "plugin must register app/settings surfaces and workbench actions")

local tools = {}
for _, tool in ipairs(plugin.tools) do
  tools[tool.name] = tool.call
end
local handlers = {}
local surface_routes = 0
local ui_actions = 0
for _, handler in ipairs(plugin.handlers) do
  handlers[handler.descriptor_id] = handler.call
  if handler.kind == "surface_route" then surface_routes = surface_routes + 1 end
  if handler.kind == "ui_action" then ui_actions = ui_actions + 1 end
end
assert(surface_routes == 2, "plugin must register app and settings surface routes")
assert(ui_actions == 5, "plugin must register every declared workbench ui_action")
assert(handlers["project_pipelines.create_ticket"] ~= nil, "create ticket ui_action must be wired")
assert(handlers["project_pipelines.record_run"] ~= nil, "record run ui_action must be wired")
assert(handlers["project_pipelines.activate_step"] ~= nil, "activate step ui_action must be wired")
assert(handlers["project_pipelines.filter"] ~= nil, "filter ui_action must be wired")
assert(handlers["project_pipelines.select_row"] ~= nil, "select row ui_action must be wired")

local empty_home = handlers["project-pipelines.home"]({})
local empty_home_sections = {}
for _, child in ipairs(empty_home.children) do
  empty_home_sections[child.id] = child
end
assert(empty_home_sections["project-pipelines-workbench"].children[1].type == "table", "empty workbench must still render project table")
assert(empty_home_sections["project-pipelines-workbench"].children[1].props.rows == nil, "empty table rows must be omitted so Lua does not serialize an empty map")
assert(empty_home_sections["project-pipelines-workbench"].children[1].props.empty_state.type == "empty_state", "empty table must carry empty_state primitive")

local project = tools["project_pipelines.create_project"]({
  id = "proj_runtime_standalone",
  name = "Runtime Standalone",
  repository = {
    id = "repo_runtime_standalone",
    name = "example/runtime-standalone",
    remote = "https://example.invalid/runtime-standalone.git",
  },
  spawn_target_id = "spawn_target_runtime",
})
assert(project.ok and project.project.workspace_id == nil, "standalone project create failed")

local linked = tools["project_pipelines.create_project"]({
  id = "proj_runtime_workspace",
  name = "Runtime Workspace",
  repository_id = "repo_runtime_workspace",
  repository_name = "example/runtime-workspace",
  repository_remote = "https://example.invalid/runtime-workspace.git",
  spawn_target_id = "spawn_target_runtime_workspace",
  workspace_id = "workspace_runtime_alpha",
})
assert(linked.ok and linked.project.workspace_id == "workspace_runtime_alpha", "workspace project create failed")

local ticket = tools["project_pipelines.create_ticket"]({
  id = "ticket_runtime_one",
  project_id = "proj_runtime_standalone",
  title = "Runtime ticket",
})
assert(ticket.ok and ticket.ticket.project_id == "proj_runtime_standalone", "ticket create failed")

local pipeline = tools["project_pipelines.define_pipeline"]({
  id = "pipeline_runtime",
  project_id = "proj_runtime_standalone",
  name = "Runtime Delivery",
  steps = {
    { id = "step_plan", name = "Plan", position = 1, gates = {
      { id = "gate_plan", kind = "attestation", prompt = "Plan is reviewable." },
    } },
    { id = "step_implement", name = "Implement", position = 2, kind = "pty", session_template_id = "template_codex_runtime", prompt = "Implement the ticket.", gates = {
      { id = "gate_tests", kind = "command", prompt = "Run script/test.", command = "script/test" },
    } },
    { id = "step_named", name = "Named", position = 3, kind = "pty", session_template_name = "Named Runtime", gates = {} },
    { id = "step_capability", name = "Capability", position = 4, kind = "pty", session_template_capability = "specialized.review", gates = {} },
    { id = "step_manual", name = "Manual", position = 5, kind = "manual", session_template_id = "template_must_not_spawn", gates = {} },
  },
})
assert(pipeline.ok and #pipeline.pipeline_definition.steps == 5, "pipeline definition failed")

local run = tools["project_pipelines.record_run"]({
  id = "run_runtime_one",
  ticket_id = "ticket_runtime_one",
  pipeline_definition_id = "pipeline_runtime",
  repository = { id = "repo_runtime_standalone", name = "example/runtime-standalone", remote = "https://example.invalid/runtime-standalone.git", path = "repo://runtime-standalone" },
  spawn_target_id = "spawn_target_runtime_override",
  branch = "project-pipelines/runtime-test",
  worktree = { kind = "provider_owned_reference", id = "worktree_runtime_one", path = "worktree://runtime-one" },
})
assert(run.ok and run.run.current_step_id == "step_plan", "run record failed")

local manual_activation = tools["project_pipelines.activate_step"]({
  run_id = "run_runtime_one",
  step_id = "step_manual",
})
assert(manual_activation.ok and manual_activation.activation.spawned == false, "manual step must not spawn a session template")

local pty_activation = tools["project_pipelines.activate_step"]({
  run_id = "run_runtime_one",
  step_id = "step_implement",
  request_id = "session_request_runtime_one",
  session_id = "session_runtime_one",
  prompt = "Runtime prompt body",
  environment = { STRING_VALUE = "kept", NUMBER_VALUE = 1 },
  metadata = { role = "implement", ignored = { "not scalar" }, numeric = 1, boolean = true },
})
assert(pty_activation.ok and pty_activation.activation.status == "spawn_requested", "PTY activation should request a hub session template spawn")
assert(pty_activation.activation.session_id == "session_runtime_one", "PTY activation should preserve caller session id")
assert(pty_activation.activation.context_id == "context_from_hub_1", "PTY activation should store returned context id")

local named_activation = tools["project_pipelines.activate_step"]({
  run_id = "run_runtime_one",
  step_id = "step_named",
  request_id = "session_request_runtime_named",
})
assert(named_activation.ok and named_activation.activation.status == "spawn_requested", "template-name activation should request a hub session template spawn")
assert(named_activation.activation.template_id == "template_named_runtime", "template-name activation should resolve the template id")
assert(named_activation.activation.template_selector.kind == "name", "template-name activation should persist selector metadata")

local capability_activation = tools["project_pipelines.activate_step"]({
  run_id = "run_runtime_one",
  step_id = "step_capability",
  request_id = "session_request_runtime_capability",
})
assert(capability_activation.ok and capability_activation.activation.status == "spawn_requested", "template-capability activation should request a hub session template spawn")
assert(capability_activation.activation.template_id == "template_capability_runtime", "template-capability activation should resolve the template id")
assert(capability_activation.activation.template_selector.kind == "capability", "template-capability activation should persist selector metadata")

local linked_ticket = tools["project_pipelines.create_ticket"]({
  id = "ticket_runtime_workspace",
  project_id = "proj_runtime_workspace",
  workspace_id = "workspace_runtime_alpha",
  title = "Runtime workspace ticket",
})
assert(linked_ticket.ok, "workspace ticket create failed")

local invalid_ticket_action = handlers["project_pipelines.create_ticket"]({
  request_id = "invalid-ticket-action",
  project_id = "proj_runtime_standalone",
  title = "   ",
})
assert(invalid_ticket_action.state == "rejected", "invalid create_ticket ui_action must reject")
assert(invalid_ticket_action.action_id == "project_pipelines.create_ticket", "invalid create_ticket action id must be preserved")
assert(invalid_ticket_action.field_errors.title[1] == "title is required", "invalid create_ticket ui_action must expose field error")

local valid_ticket_action = handlers["project_pipelines.create_ticket"]({
  request_id = "valid-ticket-action",
  id = "ticket_runtime_action",
  project_id = "proj_runtime_standalone",
  title = "Runtime action ticket",
})
assert(valid_ticket_action.state == "accepted", "valid create_ticket ui_action must accept")
assert(valid_ticket_action.payload.ok == true, "valid create_ticket ui_action must include tool payload")
assert(valid_ticket_action.payload.ticket.id == "ticket_runtime_action", "valid create_ticket ui_action must persist ticket")

local filter_action = handlers["project_pipelines.filter"]({
  request_id = "filter-action",
  status = "active",
})
assert(filter_action.state == "accepted", "filter ui_action must accept")
assert(filter_action.payload.filter == "active", "filter ui_action must echo filter payload")

local select_row_action = handlers["project_pipelines.select_row"]({
  request_id = "select-row-action",
  row_id = "run_runtime_one",
})
assert(select_row_action.state == "accepted", "select row ui_action must accept")
assert(select_row_action.payload.row_id == "run_runtime_one", "select row ui_action must echo selected row")

local linked_pipeline = tools["project_pipelines.define_pipeline"]({
  id = "pipeline_runtime_workspace",
  project_id = "proj_runtime_workspace",
  name = "Runtime Workspace Delivery",
  steps = {
    { id = "step_workspace_pty", name = "Workspace PTY", position = 1, kind = "pty", session_template_id = "template_workspace_runtime", gates = {} },
  },
})
assert(linked_pipeline.ok, "workspace pipeline definition failed")

local linked_run = tools["project_pipelines.record_run"]({
