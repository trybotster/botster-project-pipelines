local allowed_ui_node_types = {
  stack = true,
  inline = true,
  form = true,
  form_section = true,
  form_field = true,
  panel = true,
  section = true,
  toolbar = true,
  metric_grid = true,
  metric = true,
  scroll_area = true,
  text = true,
  icon = true,
  badge = true,
  status_badge = true,
  status_dot = true,
  empty_state = true,
  list = true,
  list_item = true,
  tree = true,
  tree_item = true,
  table = true,
  button = true,
  icon_button = true,
  menu = true,
  menu_item = true,
  dialog = true,
  text_input = true,
  textarea = true,
  checkbox = true,
  select = true,
  select_option = true,
  terminal_view = true,
  connection_code_view = true,
  iframe = true,
}

local function validate_ui_child_contract(child, path)
  assert(type(child) == "table", path .. " must be a table")
  if child["$kind"] ~= nil then
    assert(child["$kind"] == "bind_list" or child["$kind"] == "bind_if" or child["$kind"] == "when" or child["$kind"] == "hidden", path .. " has unsupported $kind")
    if child["$kind"] == "bind_list" then
      assert(type(child.source) == "string" and child.source:sub(1, 1) == "/", path .. " bind_list source must be absolute")
      validate_ui_child_contract(child.item_template, path .. ".item_template")
      if child.empty_template ~= nil then
        validate_ui_child_contract(child.empty_template, path .. ".empty_template")
      end
    elseif child.node ~= nil then
      validate_ui_child_contract(child.node, path .. ".node")
    end
    return
  end
  assert(allowed_ui_node_types[child.type] == true, path .. " has unsupported UiNode type " .. tostring(child.type))
  if child.type == "text" then
    assert(child.props ~= nil and child.props.text ~= nil, path .. " text node must use props.text")
  end
  if child.children ~= nil then
    assert(#child.children > 0, path .. " must omit empty children arrays for hub Lua-to-JSON compatibility")
  end
  for index, nested in ipairs(child.children or {}) do
    validate_ui_child_contract(nested, path .. ".children[" .. tostring(index) .. "]")
  end
  for slot_name, slot_children in pairs(child.slots or {}) do
    assert(type(slot_children) == "table", path .. ".slots." .. tostring(slot_name) .. " must be a child array")
    for index, nested in ipairs(slot_children) do
      validate_ui_child_contract(nested, path .. ".slots." .. tostring(slot_name) .. "[" .. tostring(index) .. "]")
    end
  end
end

