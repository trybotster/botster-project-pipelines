{
  "name": "project-pipelines",
  "version": "0.1.0",
  "kind": "plugin",
  "botster": ">=0.1.0",
  "source": { "type": "path", "path": "." },
  "capabilities": [
    { "surface": "surfaces" },
    { "surface": "mcp" },
    { "surface": "plugin_db", "scope": "project-pipelines" }
  ],
  "entrypoints": [
    { "runtime": "lua", "path": "plugin.lua", "bootstrap": false }
  ],
  "configuration": {
    "groups": [
      {
        "id": "defaults",
        "label": "Defaults"
      },
      {
        "id": "integrations",
        "label": "Integrations"
      }
    ],
    "fields": [
      {
        "key": "default_spawn_target_id",
        "type": "string",
        "label": "Default spawn target",
        "description": "Fallback hub spawn target used when a project does not provide one.",
        "group": "defaults"
      },
      {
        "key": "default_session_template_selector",
        "type": "string",
        "label": "Default session template",
        "description": "Template id, name, or capability used for PTY-backed pipeline steps without a step selector.",
        "group": "defaults"
      },
      {
        "key": "default_pipeline_mode",
        "type": "select",
        "label": "Default pipeline mode",
        "description": "Default workflow shape for new tickets.",
        "group": "defaults",
        "default": { "type": "select", "value": "botster_delivery" },
        "options": [
          { "value": "botster_delivery", "label": "Botster delivery" },
          { "value": "manual_review", "label": "Manual review" }
        ]
      },
      {
        "key": "workspace_id",
        "type": "string",
        "label": "Workspace id",
        "description": "Optional workspace reference. Standalone project records remain valid without it.",
        "group": "integrations"
      }
    ]
  },
  "navigation": [
    {
      "id": "pipelines",
      "label": "Pipelines",
      "icon": "queue-list",
      "description": "Open the Project Pipelines operator workbench.",
      "target": { "kind": "surface", "surface_id": "project-pipelines.home" }
    }
  ],
  "surfaces": [
    {
      "id": "project-pipelines.home",
      "kind": "app",
      "title": "Project Pipelines",
      "description": "Project pipeline workbench for persisted projects and tickets.",
      "icon": "queue-list",
      "order": 30,
      "category": "workflows",
      "supports": ["render", "action"]
    },
    {
      "id": "project-pipelines.settings",
      "kind": "settings",
      "title": "Project Pipelines Settings",
      "description": "Project Pipelines package settings and persistence status.",
      "icon": "adjustments-horizontal",
      "order": 30,
      "category": "workflows",
      "supports": ["render"]
    }
  ],
  "features": [
    {
      "id": "minimal_crud",
      "label": "Minimal Project Pipelines CRUD"
    },
    {
      "id": "surface_proof",
      "label": "App and settings surface proof"
    }
  ]
}
